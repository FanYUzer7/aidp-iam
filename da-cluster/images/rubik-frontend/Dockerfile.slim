# 胖更新镜像 - 基于 base 构建
# 用于离线环境用新源码构建新镜像，部署后自动运行 nginx
FROM rubik_frontend_base:latest

# 复制新源码到 build 目录
COPY data-agent-rubik/ /app/build/

# 重建前端（复用 base 的 node_modules）
WORKDIR /app/build
RUN npm run build

# 用新构建替换 nginx html 目录
RUN rm -rf /usr/share/nginx/html/* && \
    cp -r /app/build/dist/* /usr/share/nginx/html/

# 清理 build 目录（节省空间）
RUN rm -rf /app/build

# 启动 nginx 服务（k8s 可管理）
CMD ["nginx", "-g", "daemon off;"]
