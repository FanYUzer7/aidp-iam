# 基础镜像：包含 node + nginx + node_modules + 构建好的前端
# slim 基于此镜像构建新版本（复用 node_modules）
FROM node:20-alpine

# 安装 nginx
RUN apk add nginx

# 设置工作目录
WORKDIR /app

# 复制 package.json 和 package-lock.json
COPY data-agent-rubik/package*.json ./

# 安装依赖（包括 devDependencies，slim 重建时需要）
RUN npm ci

# 复制源码并构建前端
COPY data-agent-rubik/ ./
RUN npm run build

# 配置 nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 创建 nginx 运行目录
RUN mkdir -p /run/nginx

# 默认不启动 nginx（第一步先不用 nginx 启动）
CMD ["sleep", "infinity"]
