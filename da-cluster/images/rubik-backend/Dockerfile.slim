# 使用指定的基础镜像
FROM rubik-backend:base

# 设置工作区为 /workspace
WORKDIR /workspace

# 将本地构建上下文中的代码目录复制到容器工作区
# 假设 Dockerfile 与 AgentHeaven-dev/ 和 RubikSQL-dev/ 在同一级目录
COPY AgentHeaven-dev/ ./AgentHeaven-dev/
COPY RubikSQL-dev/ ./RubikSQL-dev/

# --- 安装 AgentHeaven-dev ---
WORKDIR /workspace/AgentHeaven-dev
RUN pip install . --no-deps --no-build-isolation && \
    cp -rf src/ahvn/resources/ /usr/local/lib/python3.13/site-packages/ahvn/

# --- 安装 RubikSQL-dev ---
WORKDIR /workspace/RubikSQL-dev
RUN pip install . --no-deps --no-build-isolation && \
    cp -r src/rubiksql/resources/ /usr/local/lib/python3.13/site-packages/rubiksql/

# --- 运行时初始化脚本 ---
# 切回根工作区
WORKDIR /workspace
RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -e' \
    '# 如果 ~/.ahvn 不存在配置，则运行初始化' \
    'if [ ! -f "$HOME/.ahvn/config.db" ]; then' \
    '    echo "Initializing ahvn config..."' \
    '    ahvn setup -r' \
    'fi' \
    '# 如果 ~/.rubiksql 不存在配置，则运行初始化' \
    'if [ ! -f "$HOME/.rubiksql/config.db" ]; then' \
    '    echo "Initializing rubiksql config..."' \
    '    rubiksql setup -r' \
    'fi' \
    'exec "$@"' > /entrypoint.sh && \
    chmod +x /entrypoint.sh

# 导出端口
EXPOSE 43211

# 设置入口点 - 使用运行时初始化脚本
ENTRYPOINT ["/entrypoint.sh"]
CMD ["rubiksql", "backend", "--host", "0.0.0.0", "--port", "43211"]